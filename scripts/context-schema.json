{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "_status": "PRE-DECISION PROTOTYPE - superseded by STATE.md. Uses body instead of context, missing schema_version/creator.",
  "description": "AlpheusCEF Context Node Schema v1.0",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-f0-9]{12}$",
      "description": "12-char SHA-256 hash of timestamp + body"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 creation time"
    },
    "source": {
      "type": "string",
      "description": "Originating system (cli, slack, google_docs, etc)"
    },
    "node_type": {
      "enum": ["fixed", "live"],
      "description": "fixed = snapshot, live = pointer needing resolution"
    },
    "body": {
      "type": "string",
      "minLength": 10,
      "description": "Summary or description of when this node is relevant"
    },
    "related_to": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Node IDs or file paths this connects to"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Semantic labels (decision, concern, requirement, etc)"
    },
    "meta": {
      "type": "object",
      "description": "Extensible source-specific key-value pairs"
    }
  },
  "required": ["id", "timestamp", "source", "node_type", "body"]
}
